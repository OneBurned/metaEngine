{
  "Logging": {
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "IncludeScopes": true
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "JobProcessing": {
    "LeaseDurationSeconds": 120,
    "MaximumAutomaticAttempts": 3,
    "InitialRetryDelaySeconds": 5
  }
}
